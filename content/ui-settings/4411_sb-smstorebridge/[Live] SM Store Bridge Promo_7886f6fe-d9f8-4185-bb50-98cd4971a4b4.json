{
  "execution": "single",
  "pageHead": {
    "title": "Security Bank's SM Store Weekday Shopping Promo | Giftaway"
  },
  "pages": {
    "home": {
      "template": "home-main",
      "sections": [
        {
          "id": "cover",
          "component": "cover-image",
          "props": {
            "coverUrl": "https://s3.us-east-1.amazonaws.com/assets.giftaway.ph/images/affiliates/securitybank/%5BUPDATED%5D%20SM%20Store%20Bridge%20Plan_BR%20LED%20HORIZONTAL-2%201.webp"
          },
          "classes": {
            "outer": "-mx-6"
          },
          "attrs": {
            "height": 232
          }
        },
        {
          "id": "heading",
          "component": "heading-hero",
          "props": {
            "title": "SM Store Weekday Shopping Promo!",
            "description": "$$Earn up to PHP1,000 SM Gift Pass when you shop at the SM Store on weekdays!\n\nSpend a minimum of PHP10,000 in a single-receipt straight or installment transaction to get a PHP500 SM Gift Pass using your Security Bank credit card.\n\nMaximum of two (2) redemptions per cardholder during the promo."
          }
        },
        {
          "id": "campaigns",
          "component": "campaign-standard",
          "sections": [
            {
              "id": "history",
              "component": "table-transaction",
              "props": {
                "title": "Transaction History",
                "hasTotal": false
              },
              "classes": {
                "outer": "mb-10"
              }
            }
          ]
        },
        {
          "id": "link-external",
          "component": "link-external",
          "props": {
            "label": "Terms and Conditions apply",
            "prefixIcon": "lucide:info",
            "destination": ""
          }
        },
        {
          "id": "logout",
          "component": "button-logout",
          "props": {
            "suffixIcon": "lucide:log-out",
            "label": "Log out"
          }
        },
        {
          "id": "footer",
          "component": "footer-legal-clause",
          "props": {
            "affiliate": "Securtity Bank"
          }
        }
      ]
    },
    "login": {
      "template": "login-main",
      "states": ["login", "otp", "expired"],
      "alert": {
        "component": "alert-card",
        "map": {
          "InvalidUserPassword": {
            "type": "error",
            "title": "Invalid Unique Code or Mobile Number",
            "description": "The unique code or mobile number you entered is incorrect. Please try again."
          }
        }
      },
      "sections": [
        {
          "id": "cover",
          "component": "cover-image",
          "props": {
            "coverUrl": "https://s3.us-east-1.amazonaws.com/assets.giftaway.ph/images/affiliates/securitybank/%5BUPDATED%5D%20SM%20Store%20Bridge%20Plan_BR%20LED%20HORIZONTAL-2%201.webp"
          },
          "classes": {
            "outer": "-mx-6"
          },
          "attrs": {
            "height": 232
          }
        },
        {
          "id": "heading",
          "component": "heading-hero",
          "props": {
            "title": "SM Store Weekday Shopping Promo!",
            "description": "$$Earn up to PHP1,000 SM Gift Pass when you shop at the SM Store on weekdays!\n\nSpend a minimum of PHP10,000 in a single-receipt straight or installment transaction to get a PHP500 SM Gift Pass using your Security Bank credit card.\n\nMaximum of two (2) redemptions per cardholder during the promo."
          }
        },
        {
          "id": "alert",
          "state": "login",
          "component": "alert-hero-centered",
          "props": {
            "icon": "lucide:calendar-clock",
            "title": "Promo Has Ended",
            "description": "This promotion has concluded. Thank you for participating!"
          },
          "classes": {
            "outer": "my-6",
            "icon": "bg-surface-primary text-text-primary",
            "description": "mt-0"
          }
        },
        {
          "id": "form-login",
          "component": "form-login",
          "state": "expired",
          "alert": {
            "component": "alert-card",
            "map": {
              "InvalidUserPassword": {
                "type": "error",
                "title": "Invalid Unique Code or Mobile Number",
                "description": "The unique code or mobile number you entered is incorrect. Please try again."
              }
            }
          },
          "schema": [
            {
              "$el": "h1",
              "children": "Login",
              "attrs": {
                "class": "text-2xl font-bold mb-4"
              }
            },
            {
              "$formkit": "text",
              "name": "code",
              "id": "code",
              "label": "Unique code",
              "validation": "required|length:8,8"
            },
            {
              "$formkit": "text",
              "name": "mobileNo",
              "id": "mobileno",
              "label": "Mobile number",
              "validation": [["required"], ["matches", "/^(09)[0-9]{9}$/"]],
              "placeholder": "09XX-XXX-XXXX",
              "validationMessages": {
                "matches": "Please enter a valid Philippine mobile number."
              }
            },
            {
              "$formkit": "submit",
              "type": "submit",
              "id": "submit",
              "name": "submit",
              "label": "Log in",
              "disabled": "$disabled",
              "children": {
                "if": "$disabled",
                "then": {
                  "$el": "span",
                  "attrs": {
                    "class": "w-6 h-6 border-2 border-surface-1 border-r-transparent mr-2 rounded-full animate-spin"
                  }
                },
                "else": "$label"
              }
            }
          ]
        },
        {
          "id": "divider",
          "component": "divider-horizontal-with-label",
          "state": "expired",
          "props": {
            "label": "Don't have an account?"
          },
          "classes": {
            "outer": "px-6"
          }
        },
        {
          "id": "link-internal",
          "component": "link-internal",
          "state": "expired",
          "props": {
            "destination": "/register",
            "label": "Register"
          }
        },
        {
          "id": "form-login-otp",
          "component": "form-login-otp",
          "state": "otp",
          "schema": [
            {
              "$el": "h1",
              "children": "Login Verification",
              "attrs": {
                "class": "text-2xl font-bold mb-4"
              }
            },
            {
              "$formkit": "text",
              "name": "code",
              "id": "code",
              "label": "Verification code",
              "validation": "required|length:6,6",
              "help": "Please enter the 6-digit code sent to your mobile number.",
              "sectionsSchema": {
                "input": {
                  "attrs": {
                    "autofocus": true
                  }
                },
                "help": {
                  "children": "$: 'Please enter the 6-digit code sent to ' + $mobileNo + '.'"
                }
              }
            },
            {
              "$formkit": "submit",
              "type": "submit",
              "id": "submit",
              "name": "submit",
              "label": "Proceed",
              "disabled": "$disabled",
              "children": {
                "if": "$disabled",
                "then": {
                  "$el": "span",
                  "attrs": {
                    "class": "w-6 h-6 border-2 border-surface-1 border-r-transparent mr-2 rounded-full animate-spin"
                  }
                },
                "else": "$label"
              }
            }
          ]
        },
        {
          "id": "link-external",
          "component": "link-external",
          "props": {
            "label": "Terms and Conditions apply",
            "prefixIcon": "lucide:info",
            "destination": ""
          },
          "classes": {
            "outer": "mt-20"
          },
          "attrs": {
            "target": "_blank",
            "rel": "noopener noreferrer"
          }
        },
        {
          "id": "footer",
          "component": "footer-legal-clause",
          "props": {
            "affiliate": "Securtity Bank"
          }
        }
      ]
    },
    "register": {
      "template": "register-main",
      "states": ["registration", "success", "expired"],
      "sections": [
        {
          "id": "cover",
          "component": "cover-image",
          "props": {
            "coverUrl": "https://s3.us-east-1.amazonaws.com/assets.giftaway.ph/images/affiliates/securitybank/%5BUPDATED%5D%20SM%20Store%20Bridge%20Plan_BR%20LED%20HORIZONTAL-2%201.webp"
          },
          "classes": {
            "outer": "-mx-6"
          },
          "attrs": {
            "height": 232
          }
        },
        {
          "id": "heading",
          "component": "heading-hero",
          "state": "registration",
          "props": {
            "title": "SM Store Weekday Shopping Promo!",
            "description": "$$Earn up to PHP1,000 SM Gift Pass when you shop at the SM Store on weekdays!\n\nSpend a minimum of PHP10,000 in a single-receipt straight or installment transaction to get a PHP500 SM Gift Pass using your Security Bank credit card.\n\nMaximum of two (2) redemptions per cardholder during the promo."
          }
        },
        {
          "id": "alert",
          "state": "registration",
          "component": "alert-hero-centered",
          "props": {
            "icon": "lucide:calendar-clock",
            "title": "Registration Closed",
            "description": "The registration period has ended. Thank you for your interest!"
          },
          "classes": {
            "outer": "my-6",
            "icon": "bg-surface-primary text-text-primary",
            "description": "mt-0"
          }
        },
        {
          "id": "form",
          "component": "form-register",
          "state": "expired",
          "alert": {
            "component": "alert-card",
            "map": {
              "InvalidReferenceNo": {
                "type": "error",
                "title": "Your registration was unsuccessful.",
                "description": "$$This may be due to incorrect information or mismatched details. Please retry with the correct details or contact Security Bank to update your record status if needed.\n\nT&Cs apply. Per DTI Fair Trade Permit No. FTEB-231148 Series of 2025."
              },
              "AlreadyRegisteredUsername": {
                "type": "error",
                "title": "You're already registered.",
                "description": "$$Please note that you are only required to register once.\n\nT&Cs apply. Per DTI Fair Trade Permit No. FTEB-231148 Series of 2025."
              },
              "AlreadyRegisteredReferenceNo": {
                "type": "error",
                "title": "You're already registered.",
                "description": "$$Please note that you are only required to register once.\n\nT&Cs apply. Per DTI Fair Trade Permit No. FTEB-231148 Series of 2025."
              }
            }
          },
          "schema": [
            {
              "$el": "h1",
              "children": "Register",
              "attrs": {
                "class": "text-2xl font-bold mb-4"
              }
            },
            {
              "$formkit": "text",
              "name": "code",
              "id": "code",
              "label": "Unique code",
              "validation": "required|length:8,8"
            },
            {
              "$formkit": "text",
              "name": "l4",
              "id": "l4",
              "label": "Last 4 digits of your Security Bank credit card number",
              "placeholder": "XXXX",
              "validation": "required|number|length:4,4"
            },
            {
              "$formkit": "text",
              "name": "mobileno",
              "id": "mobileno",
              "label": "Mobile number",
              "validation": [["required"], ["matches", "/^(09)[0-9]{9}$/"]],
              "placeholder": "09XX-XXX-XXXX",
              "validationMessages": {
                "matches": "Please enter a valid Philippine mobile number."
              }
            },
            {
              "$formkit": "submit",
              "type": "submit",
              "id": "submit",
              "name": "submit",
              "label": "Register",
              "disabled": "$disabled",
              "children": {
                "if": "$disabled",
                "then": {
                  "$el": "span",
                  "attrs": {
                    "class": "w-6 h-6 border-2 border-surface-1 border-r-transparent mr-2 rounded-full animate-spin"
                  }
                },
                "else": "$label"
              }
            }
          ]
        },
        {
          "id": "alert",
          "state": "success",
          "component": "alert-hero-centered",
          "props": {
            "icon": "lucide:check",
            "title": "Thank you for joining the SM Store Weekday Shopping Promo!",
            "description": "$$Start using your registered Security bank credit card for your weekday shopping at the SM Store!\n\nSpend a minimum of PHP10,000 in a single-receipt straight or installment transaction to get a PHP500 SM Gift Pass using your Security Bank credit card.\n\nMaximum of two (2) redemptions per cardholder during the promo.\n\nPer DTI Fair Trade Permit No. FTEB-231148 Series of 2025.",
            "variant": "success"
          },
          "classes": {
            "outer": "my-6"
          }
        },
        {
          "id": "link-external",
          "component": "link-external",
          "props": {
            "label": "Terms and Conditions apply",
            "prefixIcon": "lucide:info",
            "destination": "https://s3.us-east-1.amazonaws.com/assets.giftaway.ph/documents/Promo%20Mechanics%20-%20SM%20Store%20Weekday%20Deals.pdf"
          },
          "classes": {
            "outer": "mt-20"
          }
        },
        {
          "id": "footer",
          "component": "footer-legal-clause",
          "props": {
            "affiliate": "Securtity Bank"
          }
        }
      ]
    }
  },
  "theme": {
    "colors": {
      "--primary": "#07579F",
      "--primary-soft": "#E2FOFE",
      "--primary-dark": "#5AABF0",
      "--primary-dark-soft": "#0F2F4A",
      "--secondary": "#4B9ECF",
      "--secondary-soft": "#E7F2F9",
      "--secondary-dark": "#6CB4E0",
      "--secondary-dark-soft": "#1A4255"
    }
  },
  "schedule": {
    "registration": {
      "startDateTime": "",
      "endDateTime": ""
    },
    "redemption": {
      "startDateTime": "",
      "endDateTime": ""
    }
  }
}
