{
  "pageHead": {
    "title": "BPI Travel Cashback Promo | Giftaway"
  },
  "pages": {
    "home": {
      "template": "home-main",
      "sections": [
        {
          "id": "cover",
          "component": "cover-image",
          "props": {
            "coverUrl": "https://s3.us-east-1.amazonaws.com/assets.giftaway.ph/images/affiliates/bpi-engagement-test/bpi-omd-cover-2.webp"
          },
          "classes": {
            "outer": "-mx-6"
          },
          "attrs": {
            "height": "256"
          }
        },
        {
          "id": "campaign",
          "component": "accumulated-spend-single-with-dash-steps",
          "props": {
            "rewards": {},
            "progress": {}
          },
          "classes": {}
        },
        {
          "id": "logout",
          "component": "button-logout",
          "props": {
            "suffixIcon": "lucide:log-out",
            "label": "Log out"
          }
        },
        {
          "id": "footer",
          "component": "footer-legal-clause",
          "props": {
            "affiliate": "BPI"
          }
        }
      ]
    },
    "login": {
      "template": "login-with-otp",
      "states": ["login", "otp", "expired"],
      "sections": [
        {
          "id": "cover",
          "component": "cover-image",
          "props": {
            "coverUrl": "https://s3.us-east-1.amazonaws.com/assets.giftaway.ph/images/affiliates/bpi-engagement-test/bpi-omd-cover-2.webp"
          },
          "classes": {
            "outer": "-mx-6"
          },
          "attrs": {
            "height": "256"
          }
        },
        {
          "id": "heading",
          "component": "heading-hero",
          "props": {
            "title": "BPI Travel Cashback Promo",
            "description": "Get up to P10,500 cashbacks when you use your BPI Credit Card and reach your spend goals!"
          }
        },
        {
          "id": "form-login",
          "component": "form-login",
          "state": "login",
          "alert": {
            "component": "alert-card",
            "map": {
              "InvalidUserPassword": {
                "type": "error",
                "title": "Invalid Promo Code",
                "description": "The unique code or mobile number you entered is incorrect. Please try again."
              }
            }
          },
          "schema": [
            {
              "$el": "h1",
              "children": "Login",
              "attrs": {
                "class": "text-xl font-bold mb-6 text-center text-primary"
              }
            },
            {
              "$formkit": "text",
              "name": "code",
              "id": "code",
              "label": "Promo Code",
              "validation": "required|length:8,8",
              "help": "Your promo code was sent to you by BPI using your registered email address or SMS number."
            },
            {
              "$formkit": "checkbox",
              "name": "terms",
              "id": "terms",
              "label": "I have read and agree to BPI's Privacy Policy and to the Terms & Conditions",
              "validation": [["accepted"]],
              "validationLabel": "Terms and Conditions",
              "validationMessages": {
                "accepted": "Agreeing to the terms and condition is required."
              },
              "decorator-icon": "check",
              "classes": {
                "wrapper": "flex gap-x-1 items-start",
                "label": "text-xs text-neutral-500 leading-6 text-pretty",
                "inner": "mt-1 shrink-0",
                "decorator": "rounded-xs h-[20px] w-[20px]"
              },
              "sectionsSchema": {
                "label": {
                  "children": [
                    "I have read and agree to BPI's ",
                    {
                      "$el": "a",
                      "attrs": {
                        "href": "https://www.bpi.com.ph/privacy",
                        "target": "_blank",
                        "class": "underline text-primary"
                      },
                      "children": "Privacy Policy"
                    },
                    "and to the ",
                    {
                      "$el": "a",
                      "attrs": {
                        "href": "https://www.bpi.com.ph/privacy",
                        "target": "_blank",
                        "class": "underline text-primary"
                      },
                      "children": "Terms & Conditions"
                    },
                    " of this promo."
                  ]
                }
              }
            },
            {
              "$formkit": "submit",
              "type": "submit",
              "name": "submit",
              "id": "submit",
              "label": "Log in",
              "disabled": "$disabled",
              "children": {
                "if": "$disabled",
                "then": {
                  "$el": "span",
                  "attrs": {
                    "class": "w-6 h-6 border-2 border-surface-1 border-r-transparent mr-2 rounded-full animate-spin"
                  }
                },
                "else": "$label"
              }
            }
          ]
        },
        {
          "id": "divider",
          "component": "divider-horizontal-with-label",
          "state": "login"
        },
        {
          "id": "link-internal",
          "component": "markdown",
          "state": "login",
          "props": {
            "tag": "p",
            "content": "$$Not yet registered? **[Register here](Register)**"
          },
          "classes": {
            "outer": "py-3 text-text-secondary text-center border border-neutral rounded-lg h-12 text-sm"
          }
        },
        {
          "id": "form-login-otp",
          "component": "form-login-otp",
          "state": "otp",
          "schema": [
            {
              "$el": "h1",
              "children": "Login Verification",
              "attrs": {
                "class": "text-xl font-bold mb-6 text-center text-primary"
              }
            },
            {
              "$formkit": "text",
              "name": "code",
              "id": "code",
              "label": "Verification code",
              "validation": "required|length:6,6",
              "help": "Please enter the 6-digit code sent to your email adress.",
              "sectionsSchema": {
                "input": {
                  "attrs": {
                    "autofocus": true
                  }
                }
              }
            },
            {
              "$formkit": "submit",
              "type": "submit",
              "id": "submit",
              "name": "submit",
              "label": "Proceed",
              "disabled": "$disabled",
              "children": {
                "if": "$disabled",
                "then": {
                  "$el": "span",
                  "attrs": {
                    "class": "w-6 h-6 border-2 border-surface-1 border-r-transparent mr-2 rounded-full animate-spin"
                  }
                },
                "else": "$label"
              }
            }
          ]
        },
        {
          "id": "alert",
          "state": "expired",
          "component": "alert-hero-centered",
          "props": {
            "icon": "lucide:calendar-clock",
            "title": "Promo Has Ended",
            "description": "This promotion has concluded. Thank you for participating!",
            "variant": "info"
          },
          "classes": {
            "outer": "my-6",
            "icon": "bg-surface-primary text-text-primary",
            "description": "mt-0"
          }
        },
        {
          "id": "footer",
          "component": "footer-legal-clause",
          "props": {
            "affiliate": "BPI",
            "additionalContent": "Terms and conditions apply. Per DTI-FTEB Permit No. XXXXXX, Series of 2025."
          },
          "classes": {
            "outer": "mt-14"
          }
        }
      ]
    },
    "register": {
      "template": "register-main",
      "states": ["registration", "success", "expired"],
      "sections": [
        {
          "id": "cover",
          "component": "cover-image",
          "props": {
            "coverUrl": "https://s3.us-east-1.amazonaws.com/assets.giftaway.ph/images/affiliates/bpi-engagement-test/bpi-omd-cover-2.webp"
          },
          "classes": {
            "outer": "-mx-6"
          },
          "attrs": {
            "alt": "cover",
            "height": "256"
          }
        },
        {
          "id": "heading",
          "component": "heading-hero",
          "props": {
            "title": "BPI Travel Cashback Promo",
            "description": "Get up to P10,500 cashbacks when you use your BPI Credit Card and reach your spend goals!"
          }
        },
        {
          "id": "form",
          "component": "form-register",
          "state": "registration",
          "alert": {
            "component": "alert-card",
            "map": {
              "InvalidReferenceNo": {
                "type": "error",
                "title": "Invalid Promo Code",
                "description": "The promo code you have entered is INVALID. Please input the correct promo code and try again. Your promo code can be found in the email, SMS and/or Viber sent by BPI."
              },
              "AlreadyRegisteredUsername": {
                "type": "error",
                "title": "Registration Validated",
                "description": "$$Your registration has been validated. You can now track your progress. **[Log in here](login)**"
              },
              "AlreadyRegisteredReferenceNo": {
                "type": "error",
                "title": "Registration Validated",
                "description": "$$Your registration has been validated. You can now track your progress. **[Log in here](login)**"
              },
              "AccountPending": {
                "type": "error",
                "title": "Registration Pending",
                "description": "You have already registered. Your registration is currently being validated. Upon successful validation, you will receive a notification within 5-7 banking days from date of registration on your BPI registered mobile number and/or email address."
              }
            }
          },
          "schema": [
            {
              "$el": "h1",
              "children": "Register Now",
              "attrs": {
                "class": "text-xl font-bold mb-6 text-center text-primary"
              }
            },
            {
              "$formkit": "text",
              "name": "code",
              "id": "code",
              "label": "Promo code",
              "validation": "required|length:8,8",
              "help": "Your promo code was sent to you by BPI using your registered email address or SMS number."
            },
            {
              "$formkit": "checkbox",
              "name": "terms",
              "id": "terms",
              "label": "By registering, I agree that the information provided will be subject to the Terms of Service of Giftaway and BPI's Privacy Policy and the Terms & Conditions of this promo.",
              "validation": [["accepted"]],
              "validationLabel": "Terms and Conditions",
              "validationMessages": {
                "accepted": "Agreeing to the terms and condition is required."
              },
              "decorator-icon": "check",
              "classes": {
                "wrapper": "flex gap-x-1 items-start",
                "label": "text-xs text-neutral-500 leading-6 text-pretty",
                "inner": "mt-1 shrink-0",
                "decorator": "rounded-xs h-[20px] w-[20px]"
              },
              "sectionsSchema": {
                "label": {
                  "children": [
                    "By registering, I agree that the information provided will be subject to the ",
                    {
                      "$el": "a",
                      "attrs": {
                        "href": "https://giftaway.ph/terms",
                        "target": "_blank",
                        "class": "underline text-primary"
                      },
                      "children": "Terms of Service"
                    },
                    " of Giftaway and BPI's ",
                    {
                      "$el": "a",
                      "attrs": {
                        "href": "https://www.bpi.com.ph/privacy",
                        "target": "_blank",
                        "class": "underline text-primary"
                      },
                      "children": "Privacy Policy"
                    },
                    " and the ",
                    {
                      "$el": "a",
                      "attrs": {
                        "href": "",
                        "target": "_blank",
                        "class": "underline text-primary"
                      },
                      "children": "Terms & Conditions"
                    },
                    " of this promo."
                  ]
                }
              }
            },
            {
              "$formkit": "submit",
              "type": "submit",
              "id": "submit",
              "name": "submit",
              "label": "Register",
              "disabled": "$disabled",
              "children": {
                "if": "$disabled",
                "then": {
                  "$el": "span",
                  "attrs": {
                    "class": "w-6 h-6 border-2 border-surface-1 border-r-transparent mr-2 rounded-full animate-spin"
                  }
                },
                "else": "$label"
              }
            }
          ]
        },
        {
          "id": "divider",
          "component": "divider-horizontal-with-label",
          "state": "registration"
        },
        {
          "id": "link-internal",
          "component": "markdown",
          "state": "registration",
          "props": {
            "tag": "p",
            "content": "$$Already registered? **[Log in here](login)**"
          },
          "classes": {
            "outer": "py-3 text-text-secondary text-center border border-neutral rounded-lg h-12 text-sm"
          }
        },
        {
          "id": "alert",
          "state": "success",
          "component": "alert-hero-centered",
          "props": {
            "icon": "lucide:circle-check",
            "title": "Registration Submitted",
            "description": "Thank you for participating in the BPI BPI Travel Cashback Promo. This serves as your registration confirmation.",
            "iconSize": "80",
            "variant": "success"
          }
        },
        {
          "id": "alert",
          "state": "success",
          "component": "alert-card",
          "props": {
            "alerts": [
              {
                "type": "warning",
                "title": "Your date of registration is today!",
                "description": "$$Upon successful validation, you will receive a notification from Giftaway within 5 to 7 banking days on your BPI registered mobile number and/or email address.\n\nTransactions made before the date of registration are included in your spend accumulation.\n\nVisit [https://l.bpi.com.ph/sampleurl](https://l.bpi.com.ph/sampleurl) to learn more. T&Cs apply. Promo runs until September 30, 2025. Per DTI# FTEB-XXXXXX S25."
              }
            ]
          },
          "classes": {
            "outer": "mt-14  rounded-2xl!",
            "inner": "gap-5",
            "alerts": {
              "warning": {
                "title": "text-lg",
                "description": "gap-5"
              }
            }
          }
        },
        {
          "id": "alert",
          "state": "expired",
          "component": "alert-hero-centered",
          "props": {
            "icon": "lucide:calendar-clock",
            "title": "Registration Closed",
            "description": "The registration period has ended. Thank you for your interest!",
            "variant": "info"
          },
          "classes": {
            "outer": "my-6",
            "icon": "text-text-primary",
            "description": "mt-0"
          }
        },
        {
          "id": "footer",
          "component": "footer-legal-clause",
          "props": {
            "affiliate": "BPI",
            "additionalContent": "Terms and conditions apply. Per DTI-FTEB Permit No. XXXXXX, Series of 2025."
          },
          "classes": {
            "outer": "mt-14"
          }
        }
      ]
    }
  },
  "theme": {
    "colors": {
      "--primary": "#B11116",
      "--primary-soft": "#FCE3E4",
      "--primary-dark": "#E63946",
      "--primary-dark-soft": "#4A1517",
      "--secondary": "#F99C16",
      "--secondary-soft": "#FEE6AA",
      "--secondary-hard": "#C2620C",
      "--secondary-dark": "#FFB74D",
      "--secondary-dark-soft": "#4A3218",
      "--secondary-dark-hard": "#FF9800"
    }
  },
  "schedule": {
    "registration": {
      "startDateTime": "",
      "endDateTime": "2026/04/30 23:59:59"
    },
    "redemption": {
      "startDateTime": "",
      "endDateTime": "2026/05/31 23:59:59"
    }
  }
}
