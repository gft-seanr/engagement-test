    "login": {
      "template": "login-with-otp",
      "states": ["login", "otp", "expired"],
      "sections": [
        {
          "id": "cover",
          "component": "cover-image",
          "props": {
            "coverUrl": "https://s3.us-east-1.amazonaws.com/assets.giftaway.ph/images/affiliates/securitybank/COR10024_ID4537_CampaignMat-Banner-UTJ-edm.webp"
          },
          "classes": {
            "outer": "-mx-6"
          },
          "attrs": {
            "height": "216"
          }
        },
        {
          "id": "heading",
          "component": "heading-hero",
          "props": {
            "title": "Unwrap the Joy 2025 Promo",
            "description": "$$Unwrap the joy this holiday season! Spend and be rewarded with up to PHP15,000 eGC when you shop anywhere and reach the accumulated spend requirement using your Security Bank Mastercard! Plus, earn an EXTRA PHP1,000 eGC on your Installment spend.\n\nPromo is open to select cardholders who will receive the communication materials and their unique code for registration via Viber, SMS, In-app inbox or email."
          }
        },
        {
          "id": "form-login",
          "component": "form-login",
          "state": "login",
          "alert": {
            "component": "alert-card",
            "map": {
              "InvalidUserPassword": {
                "type": "error",
                "title": "Invalid Unique Code or Mobile Number",
                "description": "The unique code or mobile number you entered is incorrect. Please try again."
              }
            }
          },
          "schema": [
            {
              "$el": "h1",
              "children": "Login",
              "attrs": {
                "class": "text-2xl font-bold mb-4"
              }
            },
            {
              "$formkit": "text",
              "name": "code",
              "id": "code",
              "label": "Unique code",
              "validation": "required|length:8,8"
            },
            {
              "$formkit": "text",
              "name": "mobileNo",
              "id": "mobileno",
              "label": "Mobile number",
              "validation": [["required"], ["matches", "/^(09)[0-9]{9}$/"]],
              "placeholder": "09XX-XXX-XXXX",
              "validationMessages": {
                "matches": "Please enter a valid Philippine mobile number."
              }
            },
            {
              "$formkit": "submit",
              "type": "submit",
              "name": "submit",
              "id": "submit",
              "label": "Log in",
              "disabled": "$disabled",
              "children": {
                "if": "$disabled",
                "then": {
                  "$el": "span",
                  "attrs": {
                    "class": "w-6 h-6 border-2 border-surface-1 border-r-transparent mr-2 rounded-full animate-spin"
                  }
                },
                "else": "$label"
              }
            }
          ]
        },
        {
          "id": "divider",
          "component": "divider-horizontal-with-label",
          "state": "login",
          "props": {
            "label": "Don't have an account?"
          }
        },
        {
          "id": "link-internal",
          "component": "link-internal",
          "state": "login",
          "props": {
            "destination": "/register",
            "label": "Register"
          }
        },
        {
          "id": "form-login-otp",
          "component": "form-login-otp",
          "state": "otp",
          "schema": [
            {
              "$el": "h1",
              "children": "Login Verification",
              "attrs": {
                "class": "text-2xl font-bold mb-4"
              }
            },
            {
              "$formkit": "text",
              "name": "code",
              "id": "code",
              "label": "Verification code",
              "validation": "required|length:6,6",
              "help": "Please enter the 6-digit code sent to your mobile number.",
              "sectionsSchema": {
                "input": {
                  "attrs": {
                    "autofocus": true
                  }
                },
                "help": {
                  "children": "$: 'Please enter the 6-digit code sent to ' + $mobileNo + '.'"
                }
              }
            },
            {
              "$formkit": "submit",
              "type": "submit",
              "id": "submit",
              "name": "submit",
              "label": "Proceed",
              "disabled": "$disabled",
              "children": {
                "if": "$disabled",
                "then": {
                  "$el": "span",
                  "attrs": {
                    "class": "w-6 h-6 border-2 border-surface-1 border-r-transparent mr-2 rounded-full animate-spin"
                  }
                },
                "else": "$label"
              }
            }
          ]
        },
        {
          "id": "alert",
          "state": "expired",
          "component": "alert-hero-centered",
          "props": {
            "icon": "lucide:calendar-clock",
            "title": "Promo Has Ended",
            "description": "This promotion has concluded. Thank you for participating!",
            "variant": "info"
          },
          "classes": {
            "outer": "my-6",
            "icon": "bg-surface-primary text-text-primary",
            "description": "mt-0"
          }
        },
        {
          "id": "link-external",
          "component": "link-external",
          "props": {
            "label": "Terms and Conditions apply",
            "prefixIcon": "lucide:info",
            "destination": "https://s3.us-east-1.amazonaws.com/assets.giftaway.ph/documents/SB-COR10024_ID4537_TnCs.pdf"
          },
          "classes": {
            "outer": "mt-20"
          },
          "attrs": {
            "target": "_blank",
            "rel": "noopener noreferrer"
          }
        },
        {
          "id": "footer",
          "component": "footer-legal-clause",
          "props": {
            "affiliate": "Securtity Bank"
          }
        }
      ]
