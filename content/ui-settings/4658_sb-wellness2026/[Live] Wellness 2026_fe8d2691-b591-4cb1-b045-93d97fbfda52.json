            "component": "alert-card",
            "map": {
              "InvalidReferenceNo": {
                "type": "error",
                "title": "Your registration was unsuccessful.",
                "description": "This may be due to incorrect or mismatched details. Please retry with the correct details or contact Security Bank to update records if needed. T&Cs apply. DTI24677326."
              },
              "AlreadyRegisteredUsername": {
                "type": "error",
                "title": "You're already registered.",
                "description": "Please note that you are only required to register once. Start using your Security Bank Mastercard credit card on self-care and wellness essentials and reach the spend requirement to get eGCs! T&Cs apply. DTI24677326."
              },
              "AlreadyRegisteredReferenceNo": {
                "type": "error",
                "title": "You're already registered!",
                "description": "Please note that you are only required to register once. Start using your Security Bank Mastercard credit card on self-care and wellness essentials and reach the spend requirement to get eGCs! T&Cs apply. DTI24677326."
              }
            }
          },
          "schema": [
            {
              "$el": "h1",
              "children": "Register",
              "attrs": {
                "class": "text-2xl font-bold mb-4"
              }
            },
            {
              "$formkit": "text",
              "name": "code",
              "id": "code",
              "label": "Unique code",
              "validation": "required|length:8,8"
            },
            {
              "$formkit": "text",
              "name": "l4",
              "id": "l4",
              "label": "Last 4 digits of your Security Bank credit card number",
              "placeholder": "XXXX",
              "validation": "required|number|length:4,4"
            },
            {
              "$formkit": "text",
              "name": "mobileNo",
              "id": "mobileNo",
              "label": "Mobile number",
              "validation": [["required"], ["matches", "/^(09)[0-9]{9}$/"]],
              "placeholder": "09XX-XXX-XXXX",
              "validationMessages": {
                "matches": "Please enter a valid Philippine mobile number."
              }
            },
            {
              "$formkit": "submit",
              "type": "submit",
              "id": "submit",
              "name": "submit",
              "label": "Register",
              "disabled": "$disabled",
              "children": {
                "if": "$disabled",
                "then": {
                  "$el": "span",
                  "attrs": {
                    "class": "w-6 h-6 border-2 border-surface-1 border-r-transparent mr-2 rounded-full animate-spin"
                  }
                },
                "else": "$label"
              }
            }
          ]
        },
        {
          "id": "divider",
          "component": "divider-horizontal-with-label",
          "state": "registration",
          "props": {
            "label": "Already have an account?"
          }
        },
        {
          "id": "link-internal",
          "component": "link-internal",
          "state": "registration",
          "props": {
            "destination": "/login",
            "label": "Log in"
          }
        },
        {
          "id": "alert",
          "state": "success",
          "component": "alert-hero-centered",
          "props": {
            "title": "Registration Successful",
            "description": "You're all set! Start using your Security Bank Mastercard credit card on self-care and wellness essentials and reach the spend requirement to get eGCs! T&Cs apply. DTI24677326.",
            "variant": "success",
            "iconSize": "64"
          },
          "classes": {
            "outer": "my-6"
          }
        },
        {
          "id": "alert",
          "state": "expired",
          "component": "alert-hero-centered",
          "props": {
            "icon": "lucide:calendar-clock",
            "title": "Registration Closed",
            "description": "The registration period has ended. Thank you for your interest!",
            "variant": "info"
          },
          "classes": {
            "outer": "my-6",
            "icon": "text-text-primary",
            "description": "mt-0"
          }
        },
        {
          "id": "link-external",
          "component": "link-external",
          "props": {
            "label": "Terms and Conditions apply",
            "prefixIcon": "lucide:info",
            "destination": "https://s3.us-east-1.amazonaws.com/assets.giftaway.ph/documents/COR10024_ID4658_TnCs.pdf"
          },
          "classes": {
            "outer": "mt-20"
          }
        },
        {
          "id": "footer",
          "component": "footer-legal-clause",
          "props": {
            "affiliate": "Securtity Bank"
          }
        }
      ]
