{
  "pageHead": {
    "title": "Maya x MDC 80th Anniversary Promo | Giftaway"
  },
  "pages": {
    "home": {
      "template": "home-main",
      "sections": [
        {
          "id": "cover",
          "component": "cover-image",
          "props": {
            "coverUrl": "https://s3.us-east-1.amazonaws.com/assets.giftaway.ph/images/engagement/engagement-generic-cover.png"
          },
          "classes": {
            "outer": "-mx-6"
          },
          "attrs": {
            "alt": "Maya x MDC 80th Anniversary Cover",
            "height": "240"
          }
        },
        {
          "id": "heading",
          "component": "heading-hero",
          "props": {
            "title": "Maya x MDC 80th Anniversary Promo",
            "description": "Lorem ipsum dolor sit amet consectetur adipisicing elit. Illum quasi recusandae minima quam aliquam sed!"
          }
        },
        {
          "id": "campaigns",
          "component": "information-submission",
          "states": ["submit", "success", "expired"],
          "sections": [
            {
              "id": "redeem",
              "component": "form-submit-information",
              "state": "submit",
              "alert": {
                "component": "alert-card",
                "props": {
                  "hasIcon": true
                },
                "map": {
                  "Expired": {
                    "type": "error",
                    "title": "Submission period has ended",
                    "description": "The submission period has ended."
                  }
                }
              },
              "schema": [
                {
                  "$formkit": "text",
                  "name": "fullName",
                  "id": "fullName",
                  "label": "Full Name",
                  "validation": "required",
                  "placeholder": "Juan D. Cruz",
                  "help": "Format: First Name, Middle Initial, Last Name (as it appears on your ID)."
                },
                {
                  "$formkit": "text",
                  "name": "mobile",
                  "id": "mobile",
                  "label": "Mobile Number",
                  "validation": [["required"], ["matches", "/^(09)[0-9]{9}$/"]],
                  "placeholder": "09XX-XXX-XXXX",
                  "validationMessages": {
                    "matches": "Please enter a valid Philippine mobile number."
                  }
                },
                {
                  "$formkit": "email",
                  "name": "email",
                  "id": "email",
                  "label": "Email Address",
                  "validation": "required|email"
                },
                {
                  "$formkit": "date",
                  "name": "dateOfBirth",
                  "id": "dateOfBirth",
                  "label": "Date of Birth",
                  "validation": "required"
                },
                {
                  "$formkit": "select",
                  "name": "storelocation",
                  "id": "storelocation",
                  "label": "Store Location Area",
                  "options": ["Metro Manila", "Luzon", "Visayas", "Mindanao"],
                  "validation": "required",
                  "suffix-icon": "down"
                },
                {
                  "$formkit": "file",
                  "name": "officialReceipt",
                  "id": "officialReceipt",
                  "label": "Official Receipt",
                  "validation": "required|size:10240",
                  "accept": ".png,.jpg,.jpeg,.heic",
                  "classes": {
                    "noFiles": "text-transparent"
                  },
                  "sectionsSchema": {
                    "noFiles": {
                      "$el": "div",
                      "attrs": {
                        "class": "flex flex-col items-center justify-center px-4 py-6 text-center"
                      },
                      "children": [
                        {
                          "$cmp": "Icon",
                          "props": {
                            "name": "lucide:image-up",
                            "size": "42",
                            "class": "text-text-secondary"
                          }
                        },
                        {
                          "$el": "p",
                          "attrs": {
                            "class": "mt-4 text-xs leading-6 text-text-secondary"
                          },
                          "children": "Upload a clear and full image of the Official Receipt. Supported file types: jpg, jpeg, png or heic. Maximum file size: 10MB."
                        }
                      ]
                    }
                  }
                },
                {
                  "$formkit": "file",
                  "name": "paymentConfirmation",
                  "id": "paymentConfirmation",
                  "label": "Maya Payment Confirmation",
                  "validation": "required|size:10240",
                  "accept": ".png,.jpg,.jpeg,.heic",
                  "classes": {
                    "noFiles": "text-transparent"
                  },
                  "sectionsSchema": {
                    "noFiles": {
                      "$el": "div",
                      "attrs": {
                        "class": "flex flex-col items-center justify-center px-4 py-6 text-center"
                      },
                      "children": [
                        {
                          "$cmp": "Icon",
                          "props": {
                            "name": "lucide:image-up",
                            "size": "42",
                            "class": "text-text-secondary"
                          }
                        },
                        {
                          "$el": "p",
                          "attrs": {
                            "class": "mt-4 text-xs leading-6 text-text-secondary"
                          },
                          "children": "Upload a clear and full image of Maya payment confirmation. Supported file types: jpg, jpeg, png or heic. Maximum file size: 10MB."
                        }
                      ]
                    }
                  }
                },
                {
                  "$formkit": "submit",
                  "type": "submit",
                  "id": "submit",
                  "name": "submit",
                  "label": "Submit",
                  "disabled": "$disabled",
                  "children": {
                    "if": "$disabled",
                    "then": {
                      "$el": "span",
                      "attrs": {
                        "class": "w-6 h-6 border-2 border-surface-1 border-r-transparent mr-2 rounded-full animate-spin"
                      }
                    },
                    "else": "$label"
                  }
                }
              ]
            },
            {
              "id": "alert-success",
              "component": "alert-hero-centered",
              "state": "success",
              "props": {
                "variant": "success",
                "icon": "lucide:circle-check-big",
                "title": "Submission successful",
                "description": "You have successfully submitted your details. Lorem ipsum dolor sit amet consectetur adipisicing elit. Perferendis, iusto?"
              }
            },
            {
              "id": "alert-expired",
              "component": "alert-hero-centered",
              "state": "expired",
              "props": {
                "variant": "info",
                "title": "Promo has ended",
                "description": "The submission period has ended. Thank you for participating in the Maya x MDC 80th Anniversary Promo."
              }
            }
          ]
        },
        {
          "id": "footer",
          "component": "footer-legal-clause",
          "props": {
            "affiliate": "Maya"
          },
          "classes": {
            "outer": "mt-10"
          }
        }
      ]
    }
  },
  "theme": {
    "colors": {
      "--accent-50": "#DCFDEF",
      "--accent-100": "#C9FBE6",
      "--accent-200": "#A3F9D4",
      "--accent-300": "#7CF6C2",
      "--accent-400": "#56F4B0",
      "--accent-500": "#30F19E",
      "--accent-600": "#0FDA83",
      "--accent-700": "#0BA663",
      "--accent-800": "#087144",
      "--accent-900": "#043D24",
      "--accent-950": "#022215"
    }
  },
  "schedule": {
    "registration": {
      "startDateTime": "",
      "endDateTime": "2026/02/28 23:59:59"
    }
  }
}
