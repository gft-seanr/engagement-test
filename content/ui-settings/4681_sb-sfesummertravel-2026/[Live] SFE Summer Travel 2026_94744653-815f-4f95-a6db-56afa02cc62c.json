                "description": "You have already previously registered for the Swipe, Fly, and Earn eGCs: Summer Travel Promo 2026. Please note that you are only required to register once. Visit the official Security Bank website & search 'Swipe, Fly, and Earn eGCs' to learn more. T&Cs apply. DTI247706S26."
              },
              "AlreadyRegisteredReferenceNo": {
                "type": "error",
                "title": "You're already registered.",
                "description": "You have already previously registered for the Swipe, Fly, and Earn eGCs: Summer Travel Promo 2026. Please note that you are only required to register once. Visit the official Security Bank website & search 'Swipe, Fly, and Earn eGCs' to learn more. T&Cs apply. DTI247706S26."
              }
            }
          },
          "schema": [
            {
              "$el": "h1",
              "children": "Register",
              "attrs": {
                "class": "text-2xl font-bold mb-4"
              }
            },
            {
              "$formkit": "text",
              "name": "code",
              "id": "code",
              "label": "Unique code",
              "validation": "required|length:8,8"
            },
            {
              "$formkit": "text",
              "name": "l4",
              "id": "l4",
