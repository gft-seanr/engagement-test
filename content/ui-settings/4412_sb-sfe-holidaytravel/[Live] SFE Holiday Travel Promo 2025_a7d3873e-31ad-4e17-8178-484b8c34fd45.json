            "component": "alert-card",
            "map": {
              "InvalidReferenceNo": {
                "type": "error",
                "title": "Your registration was unsuccessful",
                "description": "$$This may be due to incorrect or mismatched details. Please retry with the correct details or contact Security Bank to update records if needed.\n\nT&Cs apply. DTI230711S25."
              },
              "AlreadyRegisteredUsername": {
                "type": "error",
                "title": "You're already registered",
                "description": "$$Please note that you are only required to register once. Earn eGCs from your travel & overseas spend with your Security Bank Mastercard credit card!\n\nT&Cs apply. DTI230711S25."
              },
              "AlreadyRegisteredReferenceNo": {
                "type": "error",
                "title": "You're already registered",
                "description": "$$Please note that you are only required to register once. Earn eGCs from your travel & overseas spend with your Security Bank Mastercard credit card!\n\nT&Cs apply. DTI230711S25."
              }
            }
          },
          "schema": [
            {
              "$el": "h1",
              "children": "Register",
              "attrs": {
                "class": "text-2xl font-bold mb-4"
